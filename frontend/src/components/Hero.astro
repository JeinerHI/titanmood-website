---
import Button from './Button.astro';
import Container from './Container.astro';
---

<section class="relative section-dark min-h-screen flex items-center overflow-hidden">
  <!-- Gradiente de fondo MÁS VISIBLE -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0e1a] via-[#1349ec]/20 to-[#0a0e1a]"></div>
  
  <!-- Círculos blur MÁS GRANDES Y VISIBLES -->
  <div class="absolute -top-32 -left-32 w-[600px] h-[600px] bg-primary rounded-full opacity-30 blur-[120px]"></div>
  <div class="absolute -bottom-32 -right-32 w-[600px] h-[600px] bg-accent-orange rounded-full opacity-25 blur-[120px]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-primary rounded-full opacity-10 blur-[100px]"></div>
  
  <!-- Grid pattern MÁS VISIBLE -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f293d30_1px,transparent_1px),linear-gradient(to_bottom,#1f293d30_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
  
  <!-- Contenido -->
  <Container class="relative z-10 py-32">
    <div class="max-w-5xl mx-auto text-center">
      <!-- Badge MÁS GRANDE Y VISIBLE -->
      <div class="inline-flex items-center gap-3 bg-gradient-to-r from-primary/20 to-accent-orange/20 border border-primary/30 rounded-full px-6 py-3 mb-10 backdrop-blur-sm">
        <span class="text-3xl">🚀</span>
        <span class="text-text-gray font-medium">Tu Compañero Definitivo de Fitness</span>
      </div>
      
      <!-- Título MUCHO MÁS GRANDE -->
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-display font-bold mb-8 leading-[1.1]">
        Transforma Tu
        <br/>
        <span class="relative inline-block mt-2">
          <span class="relative z-10 bg-gradient-to-r from-primary via-[#3b6ef5] to-accent-orange bg-clip-text text-transparent">
            Entrenamiento
          </span>
          <!-- Glow effect debajo -->
          <span class="absolute bottom-0 left-0 w-full h-6 bg-gradient-to-r from-primary/40 to-accent-orange/40 blur-2xl"></span>
        </span>
        <br/>
        <span class="text-4xl md:text-5xl lg:text-6xl text-text-gray font-normal">
          Con Inteligencia Artificial
        </span>
      </h1>
      
      <!-- Descripción MÁS GRANDE -->
      <p class="text-xl md:text-2xl text-text-gray max-w-3xl mx-auto mb-12 leading-relaxed">
        Planifica rutinas personalizadas, trackea tu progreso con RPE<br/>
        y alcanza tus objetivos fitness más rápido que nunca.
      </p>
      
      <!-- Botones MÁS GRANDES -->
      <div class="flex gap-5 justify-center flex-wrap mb-20">
        <a href="#" class="group relative inline-flex items-center gap-3 bg-gradient-to-r from-primary to-primary-dark text-white px-10 py-5 rounded-2xl font-bold text-lg transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(19,73,236,0.5)] overflow-hidden">
          <!-- Shine effect -->
          <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent translate-x-[-200%] group-hover:translate-x-[200%] transition-transform duration-1000"></span>
          <span class="relative text-2xl">📱</span>
          <span class="relative">Descargar App</span>
        </a>
        
        <a href="#" class="inline-flex items-center gap-3 bg-white/5 border-2 border-white/20 text-white px-10 py-5 rounded-2xl font-bold text-lg backdrop-blur-sm hover:bg-white/10 hover:border-white/30 transition-all duration-300 hover:scale-105">
          <span class="text-2xl">▶️</span>
          <span>Ver Demo</span>
        </a>
      </div>
      
      <!-- Stats MÁS VISUALES -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-3xl mx-auto pt-16 border-t border-white/10">
        <div class="text-center group">
          <div class="text-5xl md:text-6xl font-bold mb-3 bg-gradient-to-br from-primary to-[#3b6ef5] bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">
            10K+
          </div>
          <div class="text-text-gray text-base">Usuarios Activos</div>
        </div>
        
        <div class="text-center group">
          <div class="text-5xl md:text-6xl font-bold mb-3 bg-gradient-to-br from-accent-success to-emerald-400 bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">
            500K+
          </div>
          <div class="text-text-gray text-base">Entrenamientos Completados</div>
        </div>
        
        <div class="text-center group">
          <div class="text-5xl md:text-6xl font-bold mb-3 bg-gradient-to-br from-accent-orange to-yellow-400 bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">
            4.9
          </div>
          <div class="text-text-gray text-base">Rating en App Store</div>
        </div>
      </div>
    </div>
  </Container>
</section>