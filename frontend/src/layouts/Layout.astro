---
// src/layouts/Layout.astro
// Layout principal que envuelve todas las páginas

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = 'TitanMood - Tu compañero definitivo de entrenamiento. Planifica, trackea y alcanza tus objetivos fitness con inteligencia artificial.',
  image = '/og-image.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://titanmood.com');
const ogImage = new URL(image, Astro.site || 'https://titanmood.com');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Básico -->
    <title>{title} | TitanMood</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | TitanMood`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="TitanMood" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | TitanMood`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Importar estilos globales -->
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <!-- Aquí irá el contenido de cada página -->
    <slot />
  </body>
</html>
