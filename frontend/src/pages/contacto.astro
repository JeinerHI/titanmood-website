---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:1337/api';

// Fetch contact page data
const contactRes = await fetch(`${API_URL}/contact-page?populate[contact_info_cards][populate]=*&populate[subject_options][populate]=*`);
const contactData = await contactRes.json();

// Debug
console.log('Contact Page API response:', JSON.stringify(contactData, null, 2));

const contact = contactData.data;

// Verificar que existe
if (!contact) {
  console.error('Contact page data not found. Make sure it is published in Strapi and permissions are set.');
}

// Sort cards and options by order
const infoCards = contact?.contact_info_cards?.sort((a: any, b: any) => a.order - b.order) || [];
const subjectOptions = contact?.subject_options?.sort((a: any, b: any) => a.order - b.order) || [];

// Icon color mapping
const getIconColorClass = (color: string) => {
  switch(color) {
    case 'primary': return 'bg-primary/10 text-primary';
    case 'success': return 'bg-accent-success/10 text-accent-success';
    case 'orange': return 'bg-accent-orange/10 text-accent-orange';
    case 'warning': return 'bg-accent-warning/10 text-accent-warning';
    default: return 'bg-primary/10 text-primary';
  }
};
---

<Layout title="Contacto">
  <Navbar />
  
  <!-- Hero Section -->
  <section class="relative py-32 overflow-hidden bg-gradient-to-br from-bg-navy via-surface-navy to-bg-navy">
    <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6">
        {contact.page_title}
      </h1>
      <p class="text-xl text-white/70 max-w-3xl mx-auto">
        {contact.page_subtitle}
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Contact Info Cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {infoCards.map((card: any) => (
          <div class="text-center p-6 bg-bg-light rounded-xl">
            <div class={`w-12 h-12 ${getIconColorClass(card.icon_color)} rounded-full flex items-center justify-center mx-auto mb-3`}>
              <i class={`bi bi-${card.icon} text-xl`}></i>
            </div>
            <h3 class="font-semibold mb-1">{card.title}</h3>
            <p class="text-sm text-text-secondary">{card.content}</p>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 shadow-soft">
        <h2 class="text-3xl font-bold mb-6">{contact.form_title}</h2>
        
        <form id="contactForm" class="space-y-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-text-primary mb-2">
              Nombre completo *
            </label>
            <input 
              type="text" 
              id="name" 
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
              placeholder="Tu nombre"
            />
            <p class="text-sm text-accent-error mt-1 hidden" id="nameError">Por favor ingresa tu nombre</p>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-text-primary mb-2">
              Email *
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
              placeholder="tu@email.com"
            />
            <p class="text-sm text-accent-error mt-1 hidden" id="emailError">Por favor ingresa un email válido</p>
          </div>

          <!-- Subject -->
          <div>
            <label for="subject" class="block text-sm font-semibold text-text-primary mb-2">
              Asunto *
            </label>
            <select 
              id="subject" 
              name="subject"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
            >
              <option value="">Selecciona un tema</option>
              {subjectOptions.map((option: any) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
            <p class="text-sm text-accent-error mt-1 hidden" id="subjectError">Por favor selecciona un asunto</p>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-text-primary mb-2">
              Mensaje *
            </label>
            <textarea 
              id="message" 
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none"
              placeholder="Cuéntanos en qué podemos ayudarte..."
            ></textarea>
            <p class="text-sm text-accent-error mt-1 hidden" id="messageError">Por favor escribe tu mensaje</p>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            class="w-full bg-gradient-to-r from-primary to-primary-dark text-white px-8 py-4 rounded-xl font-bold text-lg hover:scale-[1.02] transition-all shadow-strong"
          >
            Enviar Mensaje
          </button>
        </form>

        <!-- Success Message -->
        <div id="successMessage" class="hidden mt-6 p-4 bg-accent-success/10 border border-accent-success/20 rounded-xl">
          <div class="flex items-center gap-3">
            <i class="bi bi-check-circle text-accent-success text-2xl"></i>
            <div>
              <p class="font-semibold text-accent-success">{contact.success_message_title}</p>
              <p class="text-sm text-text-secondary">{contact.success_message_text}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const successMessage = document.getElementById('successMessage');
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Email validation regex
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Get form values
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();
    
    // Reset errors
    document.querySelectorAll('[id$="Error"]').forEach(el => el.classList.add('hidden'));
    
    // Validate
    let isValid = true;
    
    if (!name || name.length < 2) {
      document.getElementById('nameError')?.classList.remove('hidden');
      isValid = false;
    }
    
    if (!email || !emailRegex.test(email)) {
      document.getElementById('emailError')?.classList.remove('hidden');
      isValid = false;
    }
    
    if (!subject) {
      document.getElementById('subjectError')?.classList.remove('hidden');
      isValid = false;
    }
    
    if (!message || message.length < 10) {
      document.getElementById('messageError')?.classList.remove('hidden');
      isValid = false;
    }
    
    if (!isValid) return;
    
    // Disable submit button
    submitButton.disabled = true;
    submitButton.textContent = 'Enviando...';
    
    try {
      // Send to Strapi API
      const API_URL = window.location.hostname === 'localhost' 
        ? 'http://localhost:1337/api'
        : '/api';
      
      const response = await fetch(`${API_URL}/contact-submissions`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          data: {
            name,
            email,
            subject,
            message,
            submitted_at: new Date().toISOString(),
            state: 'new'
          }
        })
      });
      
      if (!response.ok) {
        throw new Error('Error al enviar el mensaje');
      }
      
      // Success
      form.reset();
      successMessage?.classList.remove('hidden');
      
      // Hide success message after 5 seconds
      setTimeout(() => {
        successMessage?.classList.add('hidden');
      }, 5000);
      
    } catch (error) {
      console.error('Error:', error);
      alert('Hubo un error al enviar el mensaje. Por favor intenta de nuevo.');
    } finally {
      // Re-enable submit button
      submitButton.disabled = false;
      submitButton.textContent = 'Enviar Mensaje';
    }
  });
</script>