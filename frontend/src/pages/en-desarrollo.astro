---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="En Desarrollo | TitanMood">
  <Navbar />
  
  <!-- Main Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-bg-navy via-surface-navy to-bg-navy">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <!-- Gradient Blobs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-orange/15 rounded-full blur-[120px]"></div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-32 text-center">
      <!-- Icon -->
      <div class="mb-8 flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-primary to-accent-orange rounded-full blur-xl opacity-50"></div>
          <div class="relative w-32 h-32 bg-gradient-to-br from-primary to-primary-dark rounded-full flex items-center justify-center border-4 border-white/10">
            <i class="bi bi-tools text-6xl text-white"></i>
          </div>
        </div>
      </div>
      
      <!-- Badge -->
      <div class="inline-block bg-accent-orange/20 border border-accent-orange/30 rounded-full px-6 py-2 mb-8 backdrop-blur-sm">
        <span class="text-accent-orange font-semibold text-sm uppercase tracking-wider">Próximamente</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
        Estamos Trabajando<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-orange">
          En Esta Funcionalidad
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-xl md:text-2xl text-white/70 max-w-2xl mx-auto mb-12 leading-relaxed">
        Nuestro equipo está desarrollando esta sección para brindarte la mejor experiencia. 
        ¡Vuelve pronto para descubrir las novedades!
      </p>
      
      <!-- Features Coming Soon -->
      <div class="grid md:grid-cols-3 gap-6 mb-12 max-w-3xl mx-auto">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="w-12 h-12 bg-primary/20 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <i class="bi bi-lightning text-2xl text-primary"></i>
          </div>
          <h3 class="text-white font-semibold mb-2">Innovación</h3>
          <p class="text-white/60 text-sm">Nuevas funcionalidades revolucionarias</p>
        </div>
        
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="w-12 h-12 bg-accent-success/20 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <i class="bi bi-shield-check text-2xl text-accent-success"></i>
          </div>
          <h3 class="text-white font-semibold mb-2">Calidad</h3>
          <p class="text-white/60 text-sm">Probado y optimizado al máximo</p>
        </div>
        
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="w-12 h-12 bg-accent-orange/20 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <i class="bi bi-heart text-2xl text-accent-orange"></i>
          </div>
          <h3 class="text-white font-semibold mb-2">Experiencia</h3>
          <p class="text-white/60 text-sm">Diseñado pensando en ti</p>
        </div>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex gap-4 justify-center flex-wrap">
        <a 
          href="/"
          class="group inline-flex items-center gap-3 bg-gradient-to-r from-primary to-primary-dark text-white px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-all shadow-strong"
        >
          <i class="bi bi-house-door"></i>
          <span>Volver al Inicio</span>
        </a>
        
        <a 
          href="/blog"
          class="inline-flex items-center gap-3 bg-white/5 border-2 border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg backdrop-blur-sm hover:bg-white/10 hover:border-white/30 transition-all"
        >
          <i class="bi bi-newspaper"></i>
          <span>Visita el Blog</span>
        </a>
      </div>
      
      <!-- Progress Indicator -->
      <div class="mt-16 max-w-md mx-auto">
        <div class="flex items-center justify-between text-sm text-white/60 mb-2">
          <span>Progreso de desarrollo</span>
          <span class="text-accent-orange font-semibold">65%</span>
        </div>
        <div class="h-2 bg-white/10 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-primary via-accent-orange to-accent-success w-[65%] rounded-full relative">
            <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>