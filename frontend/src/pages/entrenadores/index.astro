---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:1337/api';

// Fetch all trainers
const trainersRes = await fetch(`${API_URL}/trainers?populate=photo&sort=name:asc`);
const trainersData = await trainersRes.json();
const trainers = trainersData.data || [];

// Debug
console.log('Trainers API response:', JSON.stringify(trainersData, null, 2));
---

<Layout title="Entrenadores">
  <Navbar />
  
  <!-- Hero Section -->
  <section class="relative py-32 overflow-hidden bg-gradient-to-br from-bg-navy via-surface-navy to-bg-navy">
    <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6">
        Nuestros <span class="text-primary">Entrenadores</span>
      </h1>
      <p class="text-xl text-white/70 max-w-3xl mx-auto">
        Profesionales certificados listos para ayudarte a alcanzar tus objetivos
      </p>
    </div>
  </section>

  <!-- Trainers Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      {trainers.length === 0 ? (
        <div class="text-center py-20">
          <i class="bi bi-people text-6xl text-text-secondary mb-4"></i>
          <p class="text-xl text-text-secondary">No hay entrenadores disponibles aún.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {trainers.map((trainer: any) => (
        <div class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-strong transition-all duration-300">
            <!-- Trainer image placeholder -->
            <div class="aspect-square overflow-hidden">
            {trainer.photo?.url ? (
                <img 
                src={import.meta.env.DEV ? `http://localhost:1337${trainer.photo.url}` : trainer.photo.url}
                alt={trainer.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
            ) : (
                <div class="w-full h-full bg-gradient-to-br from-primary/20 to-accent-orange/20 flex items-center justify-center">
                <i class="bi bi-person-circle text-8xl text-primary/40"></i>
                </div>
            )}
            </div>
            
            <!-- Trainer info -->
            <div class="p-6">
            <h2 class="text-2xl font-bold mb-2 group-hover:text-primary transition-colors">
                {trainer.name}
            </h2>
            
            {trainer.specialization && (
                <p class="text-primary font-semibold mb-3">
                {trainer.specialization}
                </p>
            )}
            
            {trainer.bio && (
                <div class="text-text-secondary mb-4 line-clamp-4">
                {trainer.bio.map((block: any) => 
                    block.children?.map((child: any) => child.text).join(' ')
                ).join(' ')}
                </div>
            )}
            
            {/* Certificaciones */}
            {trainer.certifications && (
                <div class="mb-4">
                <p class="text-sm font-semibold text-text-primary mb-2">
                    <i class="bi bi-award mr-1"></i>
                    Certificaciones
                </p>
                <div class="flex flex-wrap gap-2">
                    {trainer.certifications.split(',').map((cert: string) => (
                    <span class="text-xs bg-bg-light text-text-secondary px-2 py-1 rounded">
                        {cert.trim()}
                    </span>
                    ))}
                </div>
                </div>
            )}
            </div>
        </div>
        ))}
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>