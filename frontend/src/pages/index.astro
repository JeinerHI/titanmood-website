---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { blocksToHtml } from '../utils/blocksToHtml';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:1337/api';

// Fetch Homepage data (Strapi v5 syntax)
const homepageRes = await fetch(`${API_URL}/homepage`);
const homepageData = await homepageRes.json();
const homepage = homepageData.data;

// Fetch Feature Sections with populated components (Strapi v5 syntax)
const featuresRes = await fetch(`${API_URL}/feature-sections?populate[feature_items][populate]=*&sort=order:asc`);
const featuresData = await featuresRes.json();
const features = featuresData.data;

// Fetch Pricing Features
const pricingRes = await fetch(`${API_URL}/pricing-features?sort=order:asc`);
const pricingData = await pricingRes.json();
const pricingFeatures = pricingData.data;

// Debug logs (puedes comentarlos después)
console.log('Homepage:', homepage);
console.log('Features:', features);
console.log('Pricing:', pricingFeatures);
---

<Layout title="Inicio">
  <Navbar />
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-bg-navy via-[#1a1f35] to-bg-navy"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/30 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-orange/20 rounded-full blur-[120px]"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-32 text-center">
      <div class="inline-block bg-gradient-to-r from-accent-orange/20 to-accent-orange/10 border border-accent-orange/30 rounded-full px-5 py-2 mb-8 backdrop-blur-sm">
        <span class="text-accent-orange font-semibold text-sm">{homepage.hero_badge}</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-[1.1]">
        <div set:html={blocksToHtml(homepage.hero_title)}></div>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/70 max-w-3xl mx-auto mb-12 leading-relaxed">
        {homepage.hero_subtitle}
      </p>
      
      <div class="flex gap-4 justify-center flex-wrap mb-20">
        <a href="/en-desarrollo" class="group relative inline-flex items-center gap-3 bg-gradient-to-r from-accent-orange to-orange-600 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,107,53,0.5)] overflow-hidden">
          <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent translate-x-[-200%] group-hover:translate-x-[200%] transition-transform duration-1000"></span>
          <span class="relative">{homepage.hero_cta_primary}</span>
        </a>
        <a href="#entrena" class="inline-flex items-center gap-3 bg-white/5 border-2 border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg backdrop-blur-sm hover:bg-white/10 hover:border-white/30 transition-all duration-300">
          <span>{homepage.hero_cta_secondary}</span>
        </a>
      </div>
      
      <div class="mb-8">
        <p class="text-white/60 text-lg mb-6">
          Todo lo que necesitas, <span class="text-primary font-semibold">en un solo lugar</span>
        </p>
      </div>
      
      <div class="inline-flex bg-white/5 backdrop-blur-sm rounded-xl p-2 border border-white/10">
        {features.map((feature: any, index: number) => (
          <button 
            onclick={`showTab('${feature.tab_name}')`}
            id={`tab-${feature.tab_name}`}
            class={`tab-button px-6 py-3 rounded-lg font-semibold transition-all ${index === 0 ? 'bg-primary text-white' : 'text-white/60 bg-transparent'}`}
          >
            {feature.tab_name.charAt(0).toUpperCase() + feature.tab_name.slice(1)}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Sections (Dynamic) -->
  {features.map((feature: any, index: number) => (
    <section 
      id={`${feature.tab_name}-content`}
      class={`tab-content relative py-32 overflow-hidden ${index !== 0 ? 'hidden' : ''} ${index % 2 === 0 ? 'bg-gradient-to-br from-[#1a1f35] via-bg-navy to-[#1a1f35]' : 'bg-white'}`}
    >
      {index % 2 === 0 && (
        <>
          <div class="absolute inset-0 bg-gradient-to-br from-[#1a1f35] via-bg-navy to-[#1a1f35]"></div>
          <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.05&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        </>
      )}
      
      <div class="relative z-10 max-w-7xl mx-auto px-6">
        <div class={`grid lg:grid-cols-2 gap-16 items-center ${index === 1 ? '' : ''}`}>
          {/* Content */}
          <div class={index === 1 ? 'order-1 lg:order-2' : ''}>
            <h2 class={`text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6 leading-tight ${index % 2 === 0 ? 'text-white' : 'text-gray-900'}`}>
              <div set:html={blocksToHtml(feature.title)}></div>
            </h2>
            <p class={`text-xl mb-12 leading-relaxed ${index % 2 === 0 ? 'text-white/70' : 'text-text-secondary'}`}>
              {feature.subtitle}
            </p>
            
            <div class="space-y-8">
              {feature.feature_items.map((item: any) => (
                <div class={`${index % 2 === 0 ? 'bg-white/5 backdrop-blur-sm border border-white/10' : 'bg-bg-light border border-gray-200'} rounded-2xl p-6 hover:${index % 2 === 0 ? 'bg-white/10' : 'shadow-lg'} transition-all`}>
                  <div class="flex items-start gap-4">
                    <div class={`w-12 h-12 bg-gradient-to-br ${
                      item.badge_color === 'primary' ? 'from-primary to-primary-dark' :
                      item.badge_color === 'success' ? 'from-accent-success to-emerald-600' :
                      item.badge_color === 'orange' ? 'from-accent-orange to-orange-600' :
                      'from-accent-warning to-yellow-600'
                    } rounded-xl flex items-center justify-center flex-shrink-0`}>
                      <i class={`bi bi-${item.icon} text-2xl text-white`}></i>
                    </div>
                    <div>
                      <div class={`inline-block ${
                        item.badge_color === 'primary' ? 'bg-primary/20 text-primary' :
                        item.badge_color === 'success' ? 'bg-accent-success/20 text-accent-success' :
                        item.badge_color === 'orange' ? 'bg-accent-orange/20 text-accent-orange' :
                        'bg-accent-warning/20 text-accent-warning'
                      } font-semibold px-3 py-1 rounded-full text-xs mb-2`}>
                        {item.badge}
                      </div>
                      <h3 class={`text-xl font-bold mb-2 ${index % 2 === 0 ? 'text-white' : 'text-gray-900'}`}>
                        {item.title}
                      </h3>
                      <p class={`leading-relaxed ${index % 2 === 0 ? 'text-white/60' : 'text-text-secondary'}`}>
                        {item.description}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            
            <a href="/en-desarrollo" class={`inline-flex items-center gap-2 font-bold text-lg mt-10 hover:gap-4 transition-all group ${index % 2 === 0 ? 'text-accent-orange' : 'text-primary'}`}>
              <span>{feature.cta_text}</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
          
          {/* Mock iPhone */}
          <div class={`relative ${index === 1 ? 'order-2 lg:order-1' : ''}`}>
            <div class="relative mx-auto w-full max-w-sm">
              <!-- iPhone frame -->
              <div class="relative aspect-[9/19] bg-gradient-to-br from-surface-navy to-bg-navy rounded-[3rem] p-3 shadow-2xl border-8 border-gray-800">
                <!-- Notch -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-40 h-7 bg-gray-900 rounded-b-3xl z-10"></div>
                
                <!-- Screen content -->
                <div class="relative w-full h-full rounded-[2.5rem] overflow-hidden bg-surface-navy">
                  <img 
                    src={`/app-${feature.tab_name}.png`}
                    alt={`TitanMood - ${feature.tab_name.charAt(0).toUpperCase() + feature.tab_name.slice(1)}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </div>
              
              <!-- Glow effect -->
              <div class={`absolute inset-0 ${
                feature.tab_name === 'entrena' ? 'bg-gradient-to-br from-primary/30 to-accent-orange/30' :
                feature.tab_name === 'explora' ? 'bg-gradient-to-br from-primary/30 to-accent-success/30' :
                'bg-gradient-to-br from-accent-warning/30 to-accent-orange/30'
              } rounded-[3rem] blur-3xl -z-10`}></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Pricing Table (Dynamic) -->
  <section id="precios" class="py-32 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-display font-bold mb-4">
          <div set:html={homepage.pricing_title}></div>
        </h2>
      </div>
      
      <div class="bg-white rounded-3xl shadow-strong overflow-hidden border border-gray-100">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-surface-navy text-white">
                <th class="text-left p-6 font-bold text-lg">Funcionalidad</th>
                <th class="text-center p-6 font-bold text-lg">Gratis</th>
                <th class="text-center p-6 font-bold text-lg bg-primary/90">Pro</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {pricingFeatures.map((feature: any) => (
                <tr class="hover:bg-bg-light transition-colors">
                  <td class="p-4 font-medium">{feature.name}</td>
                  <td class="p-4 text-center">
                    {feature.free_tier ? (
                      <span class="text-accent-success text-2xl">✓</span>
                    ) : (
                      <span class="text-text-dim text-xl">—</span>
                    )}
                  </td>
                  <td class="p-4 text-center bg-primary/5">
                    {feature.pro_tier ? (
                      <span class="text-accent-success text-2xl">✓</span>
                    ) : (
                      <span class="text-text-dim text-xl">—</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      
      <p class="text-center text-text-secondary mt-8 text-sm">
        {homepage.pricing_subtitle}
      </p>
    </div>
  </section>

  <!-- Final CTA (Dynamic) -->
  <section id="cta" class="relative py-40 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-bg-navy via-[#1a1f35] to-bg-navy"></div>
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[600px] h-[600px] bg-accent-orange/15 rounded-full blur-[150px]"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p class="text-accent-orange font-bold mb-6 text-lg">{homepage.final_cta_text}</p>
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-16 leading-tight">
        <div set:html={blocksToHtml(homepage.final_cta_title)}></div>
      </h2>
      
      <div class="flex gap-5 justify-center flex-wrap mb-20">
        <a href="/en-desarrollo" class="group inline-flex items-center gap-3 bg-white text-bg-navy px-10 py-5 rounded-xl font-bold text-lg hover:scale-105 transition-all shadow-strong">
          <i class="bi bi-apple text-2xl"></i>
          <span>App Store</span>
        </a>
        <a href="/en-desarrollo" class="group inline-flex items-center gap-3 bg-gradient-to-r from-accent-success to-emerald-600 text-white px-10 py-5 rounded-xl font-bold text-lg hover:scale-105 transition-all shadow-strong">
          <i class="bi bi-google-play text-2xl"></i>
          <span>Google Play</span>
        </a>
      </div>
      
      <div class="grid grid-cols-3 gap-12 max-w-2xl mx-auto pt-12 border-t border-white/10">
        <div>
          <div class="text-5xl font-bold text-white mb-2">{homepage.stat_rating}</div>
          <div class="text-white/60 text-sm">{homepage.stat_rating_label}</div>
        </div>
        <div>
          <div class="text-5xl font-bold text-white mb-2">{homepage.stat_downloads}</div>
          <div class="text-white/60 text-sm">{homepage.stat_downloads_label}</div>
        </div>
        <div>
          <div class="text-5xl font-bold text-white mb-2">{homepage.stat_reviews}</div>
          <div class="text-white/60 text-sm">{homepage.stat_reviews_label}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />



  <!-- Tab Script -->
  <script>
    function showTab(tabName: string, shouldScroll: boolean = true): void {
      // Hide all content
      document.querySelectorAll('.tab-content').forEach(el => {
        el.classList.add('hidden');
      });
      
      // Reset all buttons to inactive state
      document.querySelectorAll('.tab-button').forEach(el => {
        el.classList.remove('bg-primary', 'text-white');
        el.classList.add('text-white/60', 'bg-transparent');
      });
      
      // Show selected content
      const content = document.getElementById(tabName + '-content');
      if (content) {
        content.classList.remove('hidden');
        
        // Only scroll if explicitly requested (not on initial load)
        if (shouldScroll) {
          content.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
      
      // Activate selected button
      const button = document.getElementById('tab-' + tabName);
      if (button) {
        button.classList.add('bg-primary', 'text-white');
        button.classList.remove('text-white/60', 'bg-transparent');
      }
    }
    
    (window as any).showTab = showTab;
    
    // Initialize first tab WITHOUT scrolling on page load
    document.addEventListener('DOMContentLoaded', () => {
      showTab('entrena', false); // false = no scroll
    });
  </script>
  <style>
    .tab-button:not(.bg-primary):hover {
      background-color: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.9);
    }
    
    .tab-button.bg-primary:hover {
      background-color: #0f3bc5; /* primary-dark */
      transform: scale(1.02);
    }
  </style>
</Layout>